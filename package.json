{
  "name": "fawxzzy-lifeline",
  "version": "0.1.0",
  "private": true,
  "description": "Lifeline v1 local operator CLI for manifest-defined apps.",
  "type": "module",
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": ">=22.14.0 <23"
  },
  "bin": {
    "lifeline": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "biome check .",
    "format": "biome format --write .",
    "validate:fitness": "node dist/cli.js validate examples/fitness-app.lifeline.yml",
    "validate:playbook": "node dist/cli.js validate examples/playbook-ui.lifeline.yml",
    "lifeline": "node dist/cli.js",
    "smoke:runtime": "node scripts/smoke-runtime.mjs",
    "smoke:playbook": "node scripts/smoke-playbook-resolution.mjs",
    "validate:fitness:mirror": "node scripts/validate-fitness-mirror.mjs",
    "test:validate-boundaries": "node scripts/test-validate-boundaries.mjs",
    "smoke:runtime:missing-env": "node scripts/smoke-runtime-missing-env.mjs",
    "smoke:runtime:restart-never": "node scripts/smoke-runtime-restart-never.mjs",
    "smoke:runtime:logs-no-history": "node scripts/smoke-runtime-logs-no-history.mjs",
    "smoke:runtime:restart-no-history": "node scripts/smoke-runtime-restart-no-history.mjs",
    "smoke:runtime:down-no-history": "node scripts/smoke-runtime-down-no-history.mjs",
    "smoke:runtime:status-no-history": "node scripts/smoke-runtime-status-no-history.mjs",
    "smoke:runtime:restore-no-history": "node scripts/smoke-runtime-restore-no-history.mjs",
    "smoke:runtime:restore-crash-loop": "node scripts/smoke-runtime-restore-crash-loop.mjs",
    "smoke:runtime:status-external-kill": "node scripts/smoke-runtime-status-external-kill.mjs",
    "smoke:runtime:status-supervisor-kill": "node scripts/smoke-runtime-status-supervisor-kill.mjs",
    "smoke:runtime:status-unhealthy": "node scripts/smoke-runtime-status-unhealthy.mjs",
    "smoke:runtime:status-blocked": "node scripts/smoke-runtime-status-blocked.mjs",
    "smoke:runtime:down-blocked-foreign-owner": "node scripts/smoke-runtime-down-blocked-foreign-owner.mjs",
    "smoke:runtime:restart-blocked-foreign-owner": "node scripts/smoke-runtime-restart-blocked-foreign-owner.mjs",
    "smoke:runtime:up-foreign-owner-port": "node scripts/smoke-runtime-up-foreign-owner-port.mjs",
    "smoke:runtime:crash-loop": "node scripts/smoke-runtime-crash-loop.mjs",
    "smoke:runtime:restore-blocked-foreign-owner": "node scripts/smoke-runtime-restore-blocked-foreign-owner.mjs",
    "smoke:runtime:restore-foreign-owner-prebind": "node scripts/smoke-runtime-restore-foreign-owner-prebind.mjs",
    "smoke:runtime:status-stale-listener-pid": "node scripts/smoke-runtime-status-stale-listener-pid.mjs",
    "smoke:runtime:restore-relaunch": "node scripts/smoke-runtime-restore-relaunch.mjs",
    "smoke:runtime:restart-playbook-persisted-path": "node scripts/smoke-runtime-restart-playbook-persisted-path.mjs",
    "smoke:runtime:restore-playbook-persisted-path": "node scripts/smoke-runtime-restore-playbook-persisted-path.mjs",
    "smoke:runtime:restore-playbook-invalid-persisted-path": "node scripts/smoke-runtime-restore-playbook-invalid-persisted-path.mjs",
    "smoke:runtime:restore-missing-working-directory": "node scripts/smoke-runtime-restore-missing-working-directory.mjs",
    "smoke:runtime:up-missing-working-directory": "node scripts/smoke-runtime-up-missing-working-directory.mjs",
    "smoke:runtime:restart-missing-working-directory": "node scripts/smoke-runtime-restart-missing-working-directory.mjs",
    "smoke:runtime:restart-missing-env-file": "node scripts/smoke-runtime-restart-missing-env-file.mjs",
    "smoke:runtime:restart-malformed-env-file": "node scripts/smoke-runtime-restart-malformed-env-file.mjs",
    "smoke:runtime:restart-playbook-invalid-persisted-path": "node scripts/smoke-runtime-restart-playbook-invalid-persisted-path.mjs",
    "smoke:runtime:restart-invalid-persisted-manifest-path": "node scripts/smoke-runtime-restart-invalid-persisted-manifest-path.mjs",
    "smoke:runtime:up-missing-env-file": "node scripts/smoke-runtime-up-missing-env-file.mjs",
    "smoke:runtime:up-malformed-env-file": "node scripts/smoke-runtime-up-malformed-env-file.mjs",
    "smoke:runtime:restore-missing-env-file": "node scripts/smoke-runtime-restore-missing-env-file.mjs",
    "test:startup-deterministic": "node scripts/test-wave2-startup-deterministic.mjs",
    "test:startup-roundtrip": "node scripts/test-startup-roundtrip-windows-deterministic.mjs",
    "verify:startup-roundtrip": "pnpm lifeline startup enable && pnpm lifeline startup status && pnpm lifeline startup disable",
    "smoke:runtime:restart-missing-required-env": "node scripts/smoke-runtime-restart-missing-required-env.mjs",
    "smoke:runtime:restore-missing-required-env": "node scripts/smoke-runtime-restore-missing-required-env.mjs",
    "smoke:runtime:restore-malformed-env-file": "node scripts/smoke-runtime-restore-malformed-env-file.mjs",
    "smoke:runtime:up-malformed-manifest": "node scripts/smoke-runtime-up-malformed-manifest.mjs",
    "smoke:runtime:restart-malformed-manifest": "node scripts/smoke-runtime-restart-malformed-manifest.mjs",
    "smoke:runtime:restore-malformed-manifest": "node scripts/smoke-runtime-restore-malformed-manifest.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "typescript": "5.8.2"
  }
}
